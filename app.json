{
  "expo": {
    "name": "AS Golf de Baugé",
    "slug": "agb_app_333",
    "version": "1.3.1",
    "orientation": "default",
    "icon": "./assets/images/logo_as_transparent.png",
    "scheme": "agbapp333",
    "userInterfaceStyle": "automatic",
    "sdkVersion": "55.0.0",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.mainault.agb_app_333"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash_as.png",
          "resizeMode": "cover",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7098e334-639c-4ee2-9d72-d833814d0751"
      }
    }
  }
}
